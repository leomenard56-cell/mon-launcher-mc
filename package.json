{
  "name": "mon-launcher-mc",
  "version": "1.0.14",
  "description": "Launcher Minecraft personnalisé avec support moddé et connexion Microsoft",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "axios": "^1.18.0",
    "minecraft-launcher-core": "^3.18.2",
    "msmc": "^5.0.5",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "electron-updater": "^4.4.4"
  },
  "overrides": {
    "form-data": "^4.0.5",
    "qs": "^6.14.1",
    "tough-cookie": "^4.1.3"
  },
  "build": {
    "appId": "com.kuroverse.launcher",
    "productName": "KuroVerse",
    "artifactName": "KuroVerse-Setup-${version}.${ext}",
    "files": [
      "**/*",
      "!node_modules/**/*.md",
      "!node_modules/**/test/**"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true
    }
  }
}
